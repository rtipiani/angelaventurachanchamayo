---
import { Image } from 'astro:assets';
import socio1 from "../assets/images/mincetur.png";
import socio2 from "../assets/images/promperu.png";
import socio3 from "../assets/images/dircetur.png";
import socio4 from "../assets/images/ytuqueplanes.png";

const socios = [
    { src: socio1, alt: "Logo MINCETUR - Ministerio de Comercio Exterior y Turismo" },
    { src: socio2, alt: "Logo PromPerú - Comisión de Promoción del Perú para la Exportación y el Turismo" },
    { src: socio3, alt: "Logo DIRCETUR Junín - Dirección Regional de Comercio Exterior y Turismo" },
    { src: socio4, alt: "Logo Y tú qué planes? - Portal de ofertas de viajes en Perú" }
];
---

<section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto text-center px-4">
        <h2 class="text-3xl md:text-4xl font-semibold mb-10">
            Socios Estratégicos
        </h2>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 items-center justify-center">
            {socios.map((socio) => (
                <div class="flex items-center justify-center p-4">
                    <Image 
                        src={socio.src} 
                        alt={socio.alt} 
                        width={200}
                        height={80}
                        class="w-full max-h-20 object-contain grayscale hover:grayscale-0 transition-all duration-300" 
                        loading="lazy"
                    />
                </div>
            ))}
        </div>
    </div>
</section>
