---
import Pagos from '../components/Pagos.astro';
import Recomendation from '../components/Recomendation.astro';
import Slider from '../components/Slider.astro';
import Socios from '../components/Socios.astro';
import Layout from '../layouts/Layout.astro';

const title = "Inicio";
const description = "Explora los mejores paquetes turísticos en Chanchamayo, Oxapampa y Pozuzo. Disfruta de la mejor experiencia de aventura y naturaleza con Angel Aventura Tours.";
const keywords = "tours Chanchamayo, tours Oxapampa, tours Selva Central, turismo Perú, operador turístico MINCETUR, Pozuzo, viajes aventura";
---
<Layout title={title} description={description} keywords={keywords}>
	<Slider />
	<Recomendation />
	<Socios />
	<Pagos />
</Layout>
