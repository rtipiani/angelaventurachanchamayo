---
import About from "../components/About";
import Certificacion from "../components/Certificacion";
import Pagos from "../components/Pagos";
import Porque from "../components/Porque";
import Responsabilidad from "../components/Responsabilidad";
import Layout from "../layouts/Layout.astro";

const title = "Sobre Nosotros";
const description = "Conoce a Angel Aventura Tours, operador turístico calificado por MINCETUR. Más de 10 años de experiencia en tours por la Selva Central del Perú.";
const keywords = "Angel Aventura Tours, operador turístico MINCETUR, tours Perú, agencia viajes Chanchamayo, experiencia turística";
---
<Layout title={title} description={description} keywords={keywords}>
    <About />
    <Porque />
    <Certificacion />
    <Pagos />
    <Responsabilidad />
</Layout>