---
import Footer from "../components/Footer";
import Navbar from "../components/Navbar";
import TopHeader from "../components/TopHeader";
import StructuredData from "../components/StructuredData.astro";
import logo from "../assets/images/logo.webp";
import slide1 from "../assets/images/slide1.png";
import { getImage } from "astro:assets";
import "../styles/global.css";

export interface Props {
	title?: string;
	description?: string;
	image?: string;
	keywords?: string;
}

const { title, description, image, keywords } = Astro.props;
const defaultTitle =
	"Angel Aventura Tours | Operador Turístico Calificado Por MINCETUR";
const finalTitle = title ? `${title} | Angel Aventura Tours` : defaultTitle;
const defaultDescription =
	"Descubre los mejores tours en la Selva Central del Perú. Operador turístico calificado por MINCETUR con más de 10 años de experiencia en Chanchamayo, Oxapampa y Pozuzo.";
const finalDescription = description || defaultDescription;
const defaultImage = "/og-image.png";
const finalImage = image || defaultImage;

// Datos estructurados para el negocio local
const organizationData = {
	name: "Angel Aventura Tours",
	description:
		"Operador turístico calificado por MINCETUR especializado en tours por la Selva Central del Perú",
	url: "https://angelaventurachanchamayo.com",
	logo: "https://angelaventurachanchamayo.com/favicon-32x32.png",
	image: "https://angelaventurachanchamayo.com/og-image.png",
	telephone: "+51 964 534 249",
	address: {
		"@type": "PostalAddress",
		streetAddress: "Jr. Tarma N° 29O",
		addressLocality: "La Merced",
		addressRegion: "Chanchamayo",
		postalCode: "12841",
		addressCountry: "PE",
	},
	geo: {
		"@type": "GeoCoordinates",
		latitude: "-11.0583",
		longitude: "-75.3283",
	},
	openingHoursSpecification: {
		"@type": "OpeningHoursSpecification",
		dayOfWeek: [
			"Monday",
			"Tuesday",
			"Wednesday",
			"Thursday",
			"Friday",
			"Saturday",
			"Sunday",
		],
		opens: "08:00",
		closes: "20:00",
	},
	sameAs: [
		"https://www.facebook.com/Angelaventuraturismochanc/",
		"https://www.instagram.com/p/DRU4YTCCc5o/",
		"https://www.tiktok.com/@angelaventurachanchamayo",
	],
	priceRange: "$$",
};

const optimizedLogo = await getImage({ src: logo, width: 300, format: 'webp' });

// Preload para el LCP (Imagen 1 del Slider)
const mobileLCP = await getImage({ src: slide1, width: 400, format: 'webp' });
const desktopLCP = await getImage({ src: slide1, width: 1920, format: 'webp' });
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{finalTitle}</title>
		<meta name="description" content={finalDescription} />
		<meta name="robots" content="index, follow" />
		{keywords && <meta name="keywords" content={keywords} />}

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={finalTitle} />
		<meta property="og:description" content={finalDescription} />
		<meta property="og:image" content={new URL('/og-image-v2.png', Astro.url)} />
		<meta property="og:image:secure_url" content={new URL('/og-image-v2.png', Astro.url)} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Angel Aventura Tours - Operador Turístico en la Selva Central" />
		<meta property="og:locale" content="es_PE" />
		<meta property="og:site_name" content="Angel Aventura Tours" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={Astro.url} />
		<meta name="twitter:title" content={finalTitle} />
		<meta name="twitter:description" content={finalDescription} />
		<meta name="twitter:image" content={new URL('/og-image-v2.png', Astro.url)} />

		<!-- Canonical URL -->
		<link rel="canonical" href={Astro.url} />

		<!-- Favicons -->
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#ffffff" />
		
		<!-- Preload LCP Images -->
		<link rel="preload" as="image" href={mobileLCP.src} media="(max-width: 640px)" />
		<link rel="preload" as="image" href={desktopLCP.src} media="(min-width: 641px)" />

		<!-- Font Awesome -->
		<link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
		<link 
			rel="stylesheet" 
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" 
			integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" 
			crossorigin="anonymous" 
			referrerpolicy="no-referrer"
			media="print"
			onload="this.media='all'"
		/>
	</head>
	<body>
		<StructuredData type="TravelAgency" data={organizationData} />
		<TopHeader />
		<Navbar client:visible logoUrl={optimizedLogo.src} />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
